; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Bakyun"
run/main_scene="uid://unffs1vlk3ih"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/image="res://assets/rstk/Ristek_Gamedev (2).png"
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://resources/audio/audio_bus_layout.tres"

[autoload]

LevelData="*res://scripts/autoload/level_data.gd"
LoadingDialogue="*res://scripts/autoload/loading_dialogue.gd"
LoadingManager="*res://scripts/autoload/loading_manager.gd"
Transition="*res://scenes/core/transition.tscn"
MusicManager="res://scenes/core/music_manager.tscn"
Dialogic="*uid://ds2q0uclmolvu"
StoryProgress="*res://scripts/autoload/story_progress.gd"
AudioManager="*res://scenes/core/world_audio_manager.tscn"
Current="*uid://dospdvoh7w2xl"
CardDatabase="*uid://7seytnrea6sn"
EnhancementManager="*res://scripts/autoload/enhancement_manager.gd"

[dialogic]

directories/dch_directory={
"baku": "res://dialogue/characters/baku.dch",
"narrator": "res://dialogue/characters/narrator.dch",
"unknown": "res://dialogue/characters/unknown.dch",

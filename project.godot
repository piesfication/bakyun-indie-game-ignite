"timeline_5": "res://dialogue/story/timeline_5.dtl",
"tut_chain": "res://dialogue/tutorials/tut_chain.dtl",
"tut_nova": "res://dialogue/tutorials/tut_nova.dtl",
"tut_overdrive": "res://dialogue/tutorials/tut_overdrive.dtl",
"tut_pierce": "res://dialogue/tutorials/tut_pierce.dtl",
"tut_practice": "res://dialogue/tutorials/tut_practice.dtl",
"tut_ultimate": "res://dialogue/tutorials/tut_ultimate.dtl"
}
layout/style_directory={
"": "res://themes/dialogic/style_1.tres",
"style_1": "res://themes/dialogic/style_1.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://themes/dialogic/style_1.tres"]
layout/default_style="res://themes/dialogic/style_1.tres"
variables={
"ChapChoose": {
"Chap1Choose": 0,
"Chap2Choose": 0,
"Chap3Choose": 0
},
"ChapterRead": {
"ReadChap1": false,
"ReadChap2": false,
"ReadChap3": false,
"ReadChap4": false,
"ReadChap5": false
},
"StoryBranch": {
"FirstOption": 0,
"SecondOption": 0
}
}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.05
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.5
text/advance_delay=0.5
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={
"\".\"": 0.1,
"—": 1.0
}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
text/absolute_autopauses=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="ignore"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "red",
"res://scenes/": "green",
"res://scripts/": "blue"
}

